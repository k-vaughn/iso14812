BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:top-levelPhysicalObjectTerms a owl:Ontology ;
    dcterms:title "Top-level Physical Object Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:centralSystem a owl:Class ;
    rdfs:subClassOf :itsComponent ;
    skos:definition "[ITS component](ITS component.md) that provides application, management, and/or administrative functions from a centralized location (3.4.1.1) [i.e. not at the [roadside](roadside.md)]"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "central system"@en ;
    :altPrefLabel "ITS central system"@en ;
    :clause "3.2.1.1"@en .

:fieldSystem a owl:Class ;
    rdfs:subClassOf :itsComponent ;
    skos:definition "infrastructure-based ITS component (3.1.8.2) located outside of a data centre that is designed to provide local processing or routing services while stationary"@en ;
    skos:example "Traffic detector, camera, signal controller, message sign, tolling station."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "Field systems can be permanently installed or transportable."@en,
        "The term \"roadside system\" is typically used to describe field systems along a roadside but can also be used to refer to kiosks."@en,
        "Typically, field systems are located along the roadside (3.3.1.10)."@en,
        "Typically, the operation of a field system is governed by management functions running in a centre system."@en ;
    skos:prefLabel "field system"@en ;
    :altPrefLabel "ITS field system"@en,
        "roadside system"@en ;
    :clause "3.2.1.2"@en .

:personalSystem a owl:Class ;
    rdfs:subClassOf :itsComponent ;
    skos:definition "[ITS component](ITS component.md), other than a [vehicle system](vehicle system.md), that is used by a [person](person.md) in relation to a past, current or upcoming journey"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "personal system"@en ;
    :altPrefLabel "ITS personal system"@en,
        "traveller system"@en ;
    :clause "3.2.1.3"@en .

:supportSystem a owl:Class ;
    rdfs:subClassOf :itsComponent ;
    skos:definition "[ITS component](ITS component.md) that provides services in support of one or more other ITS components"@en ;
    skos:example "Data distribution system (3.1.2.1), network time source, cooperative ITS (3.1.2.5) credentials management system."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "support system"@en ;
    :altPrefLabel "ITS support system"@en ;
    :clause "3.2.1.4"@en .

:vehicleSystem a owl:Class ;
    rdfs:subClassOf :itsComponent ;
    skos:definition "[ITS component](ITS component.md) that is installed as a component of a [vehicle](vehicle.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "vehicle system"@en ;
    :altPrefLabel "ITS vehicle system"@en ;
    :clause "3.2.1.5"@en .
