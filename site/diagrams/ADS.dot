// Diagram for ADS
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		ADS [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">ADS</TD></TR></TABLE>> margin=0]
	}
	drivingAutomationSystem [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">driving automation system</TD></TR></TABLE>> URL="../terms/driving automation system.md" margin=0 target=_top]
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		"ads-equippedVehicle" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ADS-equipped vehicle</TD></TR></TABLE>> URL="../terms/ADS-equipped vehicle.md" margin=0 target=_top]
		dynamicDrivingTask [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">dynamic driving task</TD></TR></TABLE>> URL="../terms/dynamic driving task.md" margin=0 target=_top]
	}
	ADS -> drivingAutomationSystem [arrowhead=onormal style=solid]
	ADS -> Invis [style=invis]
	Invis -> "ads-equippedVehicle" [style=invis]
	"ads-equippedVehicle" -> dynamicDrivingTask [style=invis]
	ADS -> "ads-equippedVehicle" [label=" can control " arrowhead=normal style=solid]
	ADS -> dynamicDrivingTask [label=" performs all of " arrowhead=normal style=solid]
}
