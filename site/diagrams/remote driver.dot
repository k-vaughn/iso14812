// Diagram for remote driver
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		"remote driver" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">remote driver</TD></TR></TABLE>> margin=0]
	}
	driver [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">driver</TD></TR></TABLE>> URL="../terms/driver.md" margin=0 target=_top]
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		nomadicVehicleInputDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">nomadic vehicle input device</TD></TR></TABLE>> URL="../terms/nomadic vehicle input device.md" margin=0 target=_top]
		remoteVehicleInputDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">remote vehicle input device</TD></TR></TABLE>> URL="../terms/remote vehicle input device.md" margin=0 target=_top]
	}
	"remote driver" -> driver [arrowhead=onormal style=solid]
	"remote driver" -> Invis [style=invis]
	Invis -> nomadicVehicleInputDevice [style=invis]
	nomadicVehicleInputDevice -> remoteVehicleInputDevice [style=invis]
	nadbe79e8025e4ed3a3c35c08f5c09bfdb5 [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1" BGCOLOR="lightyellow"><TR><TD ALIGN="CENTER">«unionOf»</TD></TR></TABLE>> margin=0]
	nadbe79e8025e4ed3a3c35c08f5c09bfdb5 -> nomadicVehicleInputDevice [label=member arrowhead=normal style=dotted]
	nadbe79e8025e4ed3a3c35c08f5c09bfdb5 -> remoteVehicleInputDevice [label=member arrowhead=normal style=dotted]
	"remote driver" -> nadbe79e8025e4ed3a3c35c08f5c09bfdb5 [label=" uses " arrowhead=normal style=solid]
}
