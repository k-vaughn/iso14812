// Diagram for taxi-share service
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		"taxi-share service" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">taxi-share service</TD></TR><TR><TD ALIGN="LEFT">financial model = commercial</TD></TR><TR><TD ALIGN="LEFT">operational model = concurrent</TD></TR><TR><TD ALIGN="LEFT">transport item = passengers</TD></TR></TABLE>> margin=0]
	}
	sharedTransportService [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">shared transport service</TD></TR></TABLE>> URL="../terms/shared transport service.md" margin=0 target=_top]
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
	}
	"taxi-share service" -> sharedTransportService [arrowhead=onormal style=solid]
}
