// Diagram for vehicle
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		vehicle [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">vehicle</TD></TR><TR><TD ALIGN="LEFT">purpose = transport ppl/goods</TD></TR></TABLE>> URL="../terms/vehicle.md" margin=0]
	}
	materialEntity [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">material entity</TD></TR></TABLE>> URL="../terms/material entity.md" margin=0 target=_top]
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		ads [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ADS</TD></TR></TABLE>> URL="../terms/ADS.md" margin=0 target=_top]
		connected [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">connected</TD></TR></TABLE>> URL="../terms/connected.md" margin=0 target=_top]
		driver [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">driver</TD></TR></TABLE>> URL="../terms/driver.md" margin=0 target=_top]
		motor [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">motor</TD></TR></TABLE>> URL="../terms/motor.md" margin=0 target=_top]
		"off-grid" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">off-grid</TD></TR></TABLE>> URL="../terms/off-grid.md" margin=0 target=_top]
		vehicleInputDevice [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">vehicle input device</TD></TR></TABLE>> URL="../terms/vehicle input device.md" margin=0 target=_top]
		wheel [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">wheel</TD></TR></TABLE>> URL="../terms/wheel.md" margin=0 target=_top]
	}
	vehicle -> materialEntity [arrowhead=onormal style=solid]
	vehicle -> Invis [style=invis]
	Invis -> ads [style=invis]
	ads -> connected [style=invis]
	connected -> driver [style=invis]
	driver -> motor [style=invis]
	motor -> "off-grid" [style=invis]
	"off-grid" -> vehicleInputDevice [style=invis]
	vehicleInputDevice -> wheel [style=invis]
	n2ae3f3e0a8a548ebaaa6f1c67d7699a2b2 [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1" BGCOLOR="lightyellow"><TR><TD ALIGN="CENTER">«unionOf»</TD></TR></TABLE>> margin=0]
	n2ae3f3e0a8a548ebaaa6f1c67d7699a2b2 -> ads [label=member arrowhead=normal style=dotted]
	n2ae3f3e0a8a548ebaaa6f1c67d7699a2b2 -> driver [label=member arrowhead=normal style=dotted]
	vehicle -> n2ae3f3e0a8a548ebaaa6f1c67d7699a2b2 [label=" DDT controlled by " arrowhead=normal style=solid]
	vehicle -> vehicleInputDevice [label=" has " arrowhead=normal style=solid]
	n2ae3f3e0a8a548ebaaa6f1c67d7699a2b8 [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1" BGCOLOR="lightyellow"><TR><TD ALIGN="CENTER">«unionOf»</TD></TR></TABLE>> margin=0]
	n2ae3f3e0a8a548ebaaa6f1c67d7699a2b8 -> connected [label=member arrowhead=normal style=dotted]
	n2ae3f3e0a8a548ebaaa6f1c67d7699a2b8 -> "off-grid" [label=member arrowhead=normal style=dotted]
	vehicle -> n2ae3f3e0a8a548ebaaa6f1c67d7699a2b8 [label=" can be " arrowhead=normal style=solid]
}
