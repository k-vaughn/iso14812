BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:vehicleComponentTerms a owl:Ontology ;
    dcterms:title "Vehicle Component Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:built-inVehicleInputDevice a owl:Class ;
    rdfs:subClassOf :vehicleInputDevice ;
    skos:definition "input device (3.7.1.4) designed to be physically connected (3.2.3.6) to a [vehicle](vehicle.md) and to remain connected even when the vehicle is not in use"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "Built-in input devices are typically considered to be a part of the vehicle."@en,
        "Built-in input devices include devices that can be temporarily disconnected (3.7.4.3) for security reasons (e.g. some radios are equipped with detachable front panels)."@en,
        "Built-in input devices require a maintenance operation to connect or disconnect."@en ;
    skos:prefLabel "built-in vehicle input device"@en ;
    :altPrefLabel "built-in input device"@en ;
    :clause "3.7.1.5"@en .

:nomadicVehicleInputDevice a owl:Class ;
    rdfs:subClassOf :vehicleInputDevice ;
    skos:definition "input device (3.7.1.4) that can be carried into, or in near proximity of, a [vehicle](vehicle.md) and [connected](connected.md) as desired"@en ;
    skos:example "A smartphone connected to a vehicle (via USB or Bluetooth) to provide driver (3.6.2.3) navigation on the vehicle's large screen display"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "NDs are often more closely associated with a person (3.1.1.6) than they are with the vehicle."@en,
        "Nomadic input devices do not require a maintenance operation to connect or disconnect."@en ;
    skos:prefLabel "nomadic vehicle input device"@en ;
    :altPrefLabel "nomadic input device"@en ;
    :clause "3.7.1.6"@en .

:remoteVehicleInputDevice a owl:Class ;
    rdfs:subClassOf :vehicleInputDevice ;
    skos:definition "input device (3.7.1.4) designed to be electronically connected (3.2.3.6) to a [vehicle](vehicle.md) even when the vehicle is not in close proximity"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "remote vehicle input device"@en ;
    :altPrefLabel "remote input device"@en ;
    :clause "3.7.1.7"@en .

:vehicle a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :driver :ads ) ] ;
            owl:onProperty :ddtControlledBy ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass :wheel ;
            owl:onProperty :has ],
        [ a owl:Restriction ;
            owl:onProperty :has ;
            owl:someValuesFrom :vehicleInputDevice ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onClass [ a owl:Class ;
                    owl:unionOf ( :off-grid :connected ) ] ;
            owl:onProperty :canBe ],
        [ a owl:Restriction ;
            owl:hasValue "transport ppl/goods"@en ;
            owl:onProperty :attrPurpose ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass :motor ;
            owl:onProperty :has ],
        :materialEntity ;
    skos:definition "[material entity](material entity.md) designed to transport people or physical goods by changing its physical position"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "vehicle"@en ;
    :clause "3.7.1.1"@en .

:attrPurpose a owl:DatatypeProperty ;
    rdfs:label "purpose"@en .

:canBe a owl:ObjectProperty ;
    rdfs:label "can be"@en .

:ddtControlledBy a owl:ObjectProperty ;
    rdfs:label "DDT controlled by"@en .

:motor a owl:Class ;
    rdfs:subClassOf :materialEntity ;
    skos:altLabel "engine"@en ;
    skos:definition "[material entity](material entity.md) that converts energy into mechanical motion"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "motor"@en ;
    :clause "3.7.1.2"@en .

:wheel a owl:Class ;
    rdfs:subClassOf :materialEntity ;
    skos:definition "circular material entity (3.1.1.3) that rotates about an axle to facilitate movement of the [vehicle](vehicle.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "wheel"@en ;
    :clause "3.7.1.3"@en .

:vehicleInputDevice a owl:Class ;
    rdfs:subClassOf :materialEntity ;
    skos:definition "[material entity](material entity.md) that can affect the [vehicle's](vehicle.md) operation"@en ;
    skos:example "steering wheel, lever, pedal, knob, button, touch screen"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "Input devices include those used to control the motion of the vehicle (e.g. a brake pedal), the state of vehicular equipment (e.g. headlight control), the configuration of the vehicle (e.g. temperature control), etc."@en ;
    skos:prefLabel "vehicle input device"@en ;
    :altPrefLabel "input device"@en ;
    :clause "3.7.1.4"@en .
