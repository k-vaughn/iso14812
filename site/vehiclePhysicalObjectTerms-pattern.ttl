BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:vehiclePhysicalObjectTerms a owl:Ontology ;
    dcterms:title "Vehicle Physical Object Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:itsOn-boardEquipment a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :comprises ;
            owl:someValuesFrom :itsOn-boardUnit ],
        :vehicleSystem ;
    skos:altLabel "onboard equipment"@en ;
    skos:definition "[vehicle system](vehicle system.md) that provides all ITS functionality on-board the [vehicle](vehicle.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "ITS on-board equipment relates to any functionality. When there is a need to distinguish between core functionality and that by a special vehicle, the term can be further refined by indicating the type of vehicle to which the on-board equipment relates. For example, emergency vehicle on-board equipment can provide specialized functionality."@en,
        "The on-board equipment may also perform other functions."@en ;
    skos:prefLabel "ITS on-board equipment"@en ;
    :altPrefLabel "OBE"@en,
        "on-board equipment"@en ;
    :clause "3.2.6.1"@en .

:itsOn-boardUnit a owl:Class ;
    rdfs:subClassOf :connectedUnit ;
    skos:altLabel "onboard unit"@en ;
    skos:definition "part of on-board equipment (3.2.6.1) that provides wireless connectivity to other ITS components (3.1.8.2) external to the [vehicle](vehicle.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "An OBU implementation can also include ITS functionality."@en ;
    skos:prefLabel "ITS on-board unit"@en ;
    :altPrefLabel "OBU"@en,
        "on-board unit"@en ;
    :clause "3.2.6.2"@en .
