BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:operationalModelTerms a owl:Ontology ;
    dcterms:title "Operational Model Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:dynamicRoute a owl:Class ;
    rdfs:subClassOf :concurrent ;
    skos:definition "<transport service> [concurrent](concurrent.md) operation where transported items can only be received or delivered at stopping points within a pre-defined [service](service.md) corridor"@en ;
    skos:example "Airport shuttle."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "The service corridor is defined by the provider, who may impose further restrictions on where stops are allowed."@en,
        "The service corridor often includes a communal point of interest (e.g. an airport, transit hub, etc.) as a fixed stopping point."@en ;
    skos:prefLabel "dynamic route"@en ;
    :clause "3.5.9.5"@en .

:fixedRoute a owl:Class ;
    rdfs:subClassOf :concurrent ;
    skos:definition "<transport service> [concurrent](concurrent.md) operation where transported items can only be received or delivered at stopping points contained in a pre-defined sequence"@en ;
    skos:example "Traditional fixed-route bus line."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "fixed route"@en ;
    :clause "3.5.9.4"@en .

:pairedOn-demand a owl:Class ;
    rdfs:subClassOf :concurrent ;
    skos:definition "<transport service> [concurrent](concurrent.md) operation where the [transport provider](transport provider.md) may choose to divert from its path to service a new request from another [transport users](transport user.md) while servicing an earlier transport user"@en ;
    skos:example "Ridesplitting."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "paired on-demand"@en ;
    :clause "3.5.9.6"@en .

:sequential a owl:Class ;
    rdfs:subClassOf :operationalModel ;
    skos:definition "[operational model](operational model.md) where [services](service.md) are provided to a single [user](user.md) at any one time"@en ;
    skos:example "Traditional taxi service."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "A single transport consumer can request the transport of multiple [passengers](passenger.md)."@en ;
    skos:prefLabel "sequential"@en ;
    :clause "3.5.9.2"@en .

:operationalModel a owl:Class ;
    skos:definition "logistical framework for the agreement between a [service provider](service provider.md) and a [user](user.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "The logistical framework can set restrictions on how a passenger (3.6.2.1) and/or good is received, transported and/or delivered."@en ;
    skos:prefLabel "operational model"@en ;
    :clause "3.5.9.1"@en .

:concurrent a owl:Class ;
    rdfs:subClassOf :operationalModel ;
    skos:definition "[operational model](operational model.md) where [services](service.md) can be provided to multiple [users](user.md) at any one time"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "concurrent"@en ;
    :clause "3.5.9.3"@en .
