BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:architectureEnterpriseViewTerms a owl:Ontology ;
    dcterms:title "Architecture Enterprise View Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:document a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 15289:2019, 3.1.10"@en ;
    rdfs:subClassOf :resource ;
    skos:definition "uniquely identified unit of information for human use"@en ;
    skos:example "A report, specification, manual or book, in printed or electronic form."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "A document can be a single information item, or part of a larger information item."@en ;
    skos:prefLabel "document"@en ;
    :clause "3.1.6.3"@en .

:enterpriseObject a owl:Class ;
    skos:definition "[element](element.md) within an [enterprise view](enterprise view.md) that represents an organization or individual"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "enterprise object"@en ;
    :clause "3.1.6.1"@en .

:extend a owl:Class ;
    rdfs:subClassOf :relationship ;
    skos:definition "<enterprise view> [relationship](relationship.md) where one [resource](resource.md) supplements another [resource](resource.md)"@en ;
    skos:example "A [module](module.md) can extend the functionality of another [module](module.md)."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "extend"@en ;
    :altPrefLabel "enterprise view extend"@en ;
    :clause "3.1.6.10"@en .

:formalCoordination a owl:Class ;
    rdfs:subClassOf :interaction ;
    skos:definition "<enterprise view> [interaction](interaction.md) between two [enterprise objects](enterprise object.md) governed by a documented agreement"@en ;
    skos:example "A road operator can enter into formal agreement(s) with the owner of a [road](road.md) and the owner(s) of the associated [ITS roadside equipment](ITS roadside equipment.md)."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "formal coordination"@en ;
    :altPrefLabel "enterprise view formal coordination"@en ;
    :clause "3.1.6.5"@en .

:include a owl:Class ;
    rdfs:subClassOf :relationship ;
    skos:definition "<enterprise view> [relationship](relationship.md) where one [resource](resource.md) contains another resource"@en ;
    skos:example "Every ITS component includes one or more [modules](module.md)."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "include"@en ;
    :altPrefLabel "enterprise view include"@en ;
    :clause "3.1.6.9"@en .

:informalCoordination a owl:Class ;
    rdfs:subClassOf :interaction ;
    skos:definition "<enterprise view> [interaction](interaction.md) between two [enterprise objects](enterprise object.md) governed by an understanding that is not documented in a formal agreement between the two parties"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "informal coordination"@en ;
    :altPrefLabel "enterprise view informal coordination"@en ;
    :clause "3.1.6.6"@en .

:role a owl:Class ;
    dcterms:source "ISO/IEC 11179-3:2013, 3.2.121"@en ;
    skos:definition "<enterprise view> [element](element.md) that represents the specified responsibilities between an [enterprise object](enterprise object.md) and another [enterprise view](enterprise view.md) element"@en,
        "specified responsibilities"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "role"@en ;
    :altPrefLabel "enterprise view role"@en ;
    :clause "3.1.12.3"@en,
        "3.1.6.7"@en .

:resource a owl:Class ;
    skos:definition "<enterprise view> [element](element.md) that represents an [entity](entity.md) that is managed, operated, referenced and/or used to develop and provide [ITS](intelligent transport system.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "resource"@en ;
    :altPrefLabel "enterprise view resource"@en ;
    :clause "3.1.6.2"@en .

:interaction a owl:Class ;
    skos:definition "<enterprise view> [element](element.md) that represents coordination between two [enterprise objects](enterprise object.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "interaction"@en ;
    :altPrefLabel "enterprise view interaction"@en ;
    :clause "3.1.6.4"@en .

:relationship a owl:Class ;
    skos:definition "<enterprise view> [element](element.md) that represents an association between two [resources](resource.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "relationship"@en ;
    :altPrefLabel "enterprise view relationship"@en ;
    :clause "3.1.6.8"@en .
