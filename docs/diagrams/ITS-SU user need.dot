// Diagram for ITS-SU user need
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		"ITS-SU user need" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">ITS-SU user need</TD></TR></TABLE>> margin=0]
	}
	userNeed [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">user need</TD></TR></TABLE>> URL="../terms/user need/" margin=0 target=_top]
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		boundedSecuredManagedDomain [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">bounded secured managed domain</TD></TR></TABLE>> URL="../terms/bounded secured managed domain/" margin=0 target=_top]
	}
	"ITS-SU user need" -> userNeed [arrowhead=onormal style=solid]
	"ITS-SU user need" -> Invis [style=invis]
	Invis -> boundedSecuredManagedDomain [style=invis]
	"ITS-SU user need" -> boundedSecuredManagedDomain [label=" requires processing within " arrowhead=normal style=solid]
}
