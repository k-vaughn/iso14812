BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:dataConceptTypeTerms a owl:Ontology ;
    dcterms:title "Data Concept Type Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:interfaceDialogue a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :uses ;
            owl:someValuesFrom :message ],
        :dataConcept ;
    skos:altLabel "dialog"@en,
        "dialogue"@en ;
    skos:definition "bi-directional communication sequence between two parties in accordance with predetermined protocols"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "The term \"dialog\" represents the American English spelling."@en,
        "The term \"dialogue\" can be used when the interface context is known."@en ;
    skos:prefLabel "interface dialogue"@en ;
    :clause "3.1.11.6"@en .

:class a owl:Class ;
    dcterms:source "ISO/IEC 11179-1:2015, 3.3.18, modified - term changed to from \"object class\" to \"class\" and Notes to entry added."@en ;
    rdfs:subClassOf :dataConcept ;
    skos:altLabel "object class"@en ;
    skos:definition "set of ideas, abstractions or things in the real world that are identified with explicit boundaries and meaning and whose properties and behaviour follow the same rules"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "Some ISO/TC 204 documents use the term \"object class\" for consistency with ISO 11179-1, but within ITS, the term \"class\" is more generally understood."@en,
        "This is semantically equivalent to a \"class\" as used within UML (ISO19505-2:2012)."@en ;
    skos:prefLabel "class"@en ;
    :clause "3.1.11.2"@en .

:dataElement a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onClass :valueDomain ;
            owl:onProperty :representedBy ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:onClass :class ;
            owl:onProperty :describes ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :dataConcept ;
    skos:definition "unit of data that is considered in a given context to be indivisible and which includes an unambiguous representational form"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "This definition states that a data element is \"indivisible\" in a given context. This means it is possible for a data element considered indivisible in one context [e.g. [location](location.md)] to be divisible in another context (e.g. latitude, longitude, and elevation)."@en ;
    skos:prefLabel "data element"@en ;
    :clause "3.1.11.1"@en .

:dataFrame a owl:Class ;
    rdfs:subClassOf :dataConcept ;
    skos:definition "specific grouping of [data elements](data element.md) that describes information of interest through a useful grouping of more atomic properties about one or more [classes](class.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "A data frame can contain other data frames."@en,
        "The grouping can be a set, sequence or a choice."@en ;
    skos:prefLabel "data frame"@en ;
    :clause "3.1.11.4"@en .

:message a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass :dataFrame ;
            owl:onProperty :contains ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger ;
            owl:onClass :dataElement ;
            owl:onProperty :contains ],
        :dataConcept ;
    skos:definition "grouping of [data elements](data element.md), [data frames](data frame.md), or data elements and data frames that is used to convey information"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "message"@en ;
    :clause "3.1.11.5"@en .

:representedBy a owl:ObjectProperty ;
    rdfs:label "represented by"@en .

:valueDomain a owl:Class ;
    rdfs:subClassOf :dataConcept ;
    skos:definition "a set of permissible values"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "value domain"@en ;
    :clause "3.1.11.3"@en .
