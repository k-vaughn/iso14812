BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:conceptRealizationTerms a owl:Ontology ;
    dcterms:title "Concept Realization Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:design a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 24765:2017, definitions 1 and 2 merged, example added"@en ;
    skos:definition "the process or the result of the process to define the architecture, system elements, interfaces, and other characteristics of a system or system element"@en ;
    skos:example "Example: Complete documentation for building a specific model of a smartphone"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2025"@en ;
    skos:note "Design provides the detailed implementation-level physical structure, behaviour, temporal relationships, and other attributes of system elements. It is information including specification of system elements and their relationships, that is sufficiently complete to support a compliant implementation of the architecture,"@en ;
    skos:prefLabel "design"@en ;
    :clause "3.1.15.1"@en .

:implementation a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 24765:2017, definitions 1 and 2 merged with example and note added"@en ;
    skos:definition "the process or the result of the process of translating a design into hardware components, software components, or both"@en ;
    skos:example "Example: The process of building a specific model of a smartphone or the resultant model of smartphone"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2025"@en ;
    skos:note "An implementation is the conceptual set of all instances of a product resulting from the translation. The set of all instances can consist of a single instance."@en ;
    skos:prefLabel "implementation"@en ;
    :clause "3.1.15.2"@en .

:instance a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 24765:2017, definition 1, example and note added"@en ;
    skos:definition "discrete, bounded object with an intrinsic, immutable, and unique identity"@en ;
    skos:example "Example: A specific smartphone (e.g., having a unique serial number)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2025"@en ;
    skos:note "An instance of an implementation can also be called a physical instantiation, in the case of a hardware component."@en ;
    skos:prefLabel "instance"@en ;
    :clause "3.1.15.3"@en .

:realization a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 24765:2017, example added"@en ;
    skos:definition "implementation of a system concept"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2025"@en ;
    skos:note "A realization requires the development of a design and the translation of this design into hardware components, software components, or both."@en ;
    skos:prefLabel "realization"@en ;
    :clause "3.1.15.4"@en .

:requirement a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 24765:2017, example added"@en ;
    skos:definition "provision that contains criteria to be fulfilled"@en ;
    skos:example "Example: A measurable characteristic of a smartphone"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2025"@en ;
    skos:prefLabel "requirement"@en ;
    :clause "3.1.15.5"@en .

:requirementsSpecification a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 24765:2017, example and note added"@en ;
    skos:definition "document that specifies the requirements for a system or component"@en ;
    skos:example "Example: Wi-Fi 7, 5G, Bluetooth 5.3"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2025"@en ;
    skos:note "A device can conform to multiple requirements specifications, each with a different focus."@en ;
    skos:prefLabel "requirements specification"@en ;
    :clause "3.1.15.6"@en .
