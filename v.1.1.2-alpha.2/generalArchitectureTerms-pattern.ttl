BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:generalArchitectureTerms a owl:Ontology ;
    dcterms:title "General Architecture Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:architectureFramework a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.4"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :conventionsPrinciplesAndPracticesFor ;
            owl:someValuesFrom :architectureDescription ] ;
    skos:definition "conventions, principles and practices for the description of [architectures](architecture.md) established within a specific domain of application and/or community of [stakeholders](stakeholder.md)"@en ;
    skos:example "Generalised Enterprise Reference Architecture and Methodologies (GERAM) [ISO 15704] is an architecture framework."@en,
        "Reference Model of Open Distributed Processing (RM-ODP) [ISO/IEC 10746] is an architecture framework."@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "architecture framework"@en ;
    :clause "3.1.3.3"@en .

:environment a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.8"@en ;
    skos:definition "<system> context determining the setting and circumstances of all influences upon a [system](system.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "The environment of a system includes developmental, technological, business, operational, organizational, political, economic, legal, regulatory, ecological and social influences."@en ;
    skos:prefLabel "environment"@en ;
    :altPrefLabel "system environment"@en ;
    :clause "3.1.3.11"@en .

:architecture a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.2"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :aggregates ;
            owl:someValuesFrom :element ] ;
    skos:definition "<system> fundamental concepts or properties of a [system](system.md) in its [environment](environment.md) embodied in its [elements](element.md), [relationships](relationship.md) and in the principles of its design and evolution"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "architecture"@en ;
    :altPrefLabel "system architecture"@en ;
    :clause "3.1.3.1"@en .

:architectureDescription a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.3"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :aggregates ;
            owl:someValuesFrom :architectureViewpoint ],
        [ a owl:Restriction ;
            owl:onProperty :identifies ;
            owl:someValuesFrom :stakeholder ],
        [ a owl:Restriction ;
            owl:onProperty :identifies ;
            owl:someValuesFrom :concern ],
        [ a owl:Restriction ;
            owl:onProperty :aggregates ;
            owl:someValuesFrom :architectureView ],
        [ a owl:Restriction ;
            owl:onProperty :identifies ;
            owl:someValuesFrom :system ],
        [ a owl:Restriction ;
            owl:onProperty :expresses ;
            owl:someValuesFrom :architecture ] ;
    skos:definition "work product used to express an [architecture](architecture.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "architecture description"@en ;
    :clause "3.1.3.2"@en .

:architectureViewpoint a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.6"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :aggregates ;
            owl:someValuesFrom :modelKind ],
        [ a owl:Restriction ;
            owl:onProperty :governs ;
            owl:someValuesFrom :architectureView ],
        [ a owl:Restriction ;
            owl:onProperty :frames ;
            owl:someValuesFrom :concern ] ;
    skos:definition "work product establishing the conventions for the construction, interpretation and use of [architecture views](architecture view.md) to frame specific system [concerns](concern.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "architecture viewpoint"@en ;
    :clause "3.1.3.6"@en .

:conventionsPrinciplesAndPracticesFor a owl:ObjectProperty ;
    rdfs:label "conventions, principles, and practices for"@en .

:element a owl:Class ;
    skos:definition "<architecture> component member of an [architecture model](architecture model.md) included in an [architecture view](architecture view.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "element"@en ;
    :altPrefLabel "architecture element"@en ;
    :clause "3.1.3.10"@en .

:expresses a owl:ObjectProperty .

:frames a owl:ObjectProperty .

:modelKind a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.9"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :governs ;
            owl:someValuesFrom :architectureModel ] ;
    skos:definition "conventions for a type of modelling"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "Examples of model kinds include [data flow](data flow.md) diagrams, [class](class.md) diagrams, Petri nets, balance sheets, organization charts and state transition models."@en ;
    skos:prefLabel "model kind"@en ;
    :clause "3.1.3.8"@en .

:stakeholder a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.10"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :has ;
            owl:someValuesFrom :concern ] ;
    skos:definition "<system> individual, team, organization, or [classes](class.md) thereof, having an interest in a [system](system.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "stakeholder"@en ;
    :altPrefLabel "system stakeholder"@en ;
    :clause "3.1.3.4"@en .

:architectureModel a owl:Class ;
    skos:definition "work product representing one or more [architecture views](architecture view.md) and expressed in a format governed by a [model kind](model kind.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "architecture model"@en ;
    :clause "3.1.3.9"@en .

:architectureView a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.5"@en ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :aggregates ;
            owl:someValuesFrom :architectureModel ] ;
    skos:definition "work product expressing the [architecture](architecture.md) of a [system](system.md) from the perspective of specific system [concerns](concern.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "architecture view"@en ;
    :clause "3.1.3.7"@en .

:concern a owl:Class ;
    dcterms:source "ISO/IEC/IEEE 42010:2011, 3.7"@en ;
    skos:definition "<system> interest in a [system](system.md) relevant to one or more of its [stakeholders](stakeholder.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "A concern pertains to any influence on a system in its [environment](environment.md), including developmental, technological, business, operational, organizational, political, economic, legal, regulatory, ecological and social influences."@en ;
    skos:prefLabel "concern"@en ;
    :altPrefLabel "system concern"@en ;
    :clause "3.1.3.5"@en .
