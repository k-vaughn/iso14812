// Diagram for ITS service
digraph {
	graph [overlap=false rankdir=TB splines=true]
	node [fontname=Arial fontsize=12 margin=0 shape=none]
	edge [fontname=Arial fontsize=11]
	{
		rank=max
		"ITS service" [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER" PORT="e">ITS service</TD></TR></TABLE>> margin=0]
	}
	service [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">service</TD></TR></TABLE>> URL="../terms/service/" margin=0 target=_top]
	subgraph cluster_associated {
		label="" style=invis
		Invis [label=<<TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD></TD></TR></TABLE>> margin=0 style=invis]
		itsUser [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ITS user</TD></TR></TABLE>> URL="../terms/ITS user/" margin=0 target=_top]
		itsUserNeed [label=<<TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="1"><TR><TD BGCOLOR="lightgray" ALIGN="CENTER">ITS user need</TD></TR></TABLE>> URL="../terms/ITS user need/" margin=0 target=_top]
	}
	"ITS service" -> service [arrowhead=onormal style=solid]
	"ITS service" -> Invis [style=invis]
	Invis -> itsUser [style=invis]
	itsUser -> itsUserNeed [style=invis]
	"ITS service" -> itsUser [label=" for " arrowhead=normal style=solid]
	"ITS service" -> itsUserNeed [label=" fulfils " arrowhead=normal style=solid]
}
