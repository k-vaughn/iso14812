BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:sharedVehicleTerms a owl:Ontology ;
    dcterms:title "Shared Vehicle Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:bikesharingService a owl:Class ;
    rdfs:subClassOf :sharedVehicleService ;
    skos:altLabel "bicycle sharing service"@en ;
    skos:definition "[shared vehicle service](shared vehicle service.md) that shares bicycles"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "The term \"bicycle sharing service\" is admitted, but \"bikesharing service\" is preferred as it has fewer syllables."@en ;
    skos:prefLabel "bikesharing service"@en ;
    :clause "3.5.12.1"@en .

:carsharingService a owl:Class ;
    rdfs:subClassOf :sharedVehicleService ;
    skos:altLabel "passenger car sharing service"@en ;
    skos:definition "[shared vehicle service](shared vehicle service.md) that shares [passenger](passenger.md) cars"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "The term \"passenger car sharing service\" is admitted but has the same meaning."@en ;
    skos:prefLabel "carsharing service"@en ;
    :clause "3.5.12.2"@en .
