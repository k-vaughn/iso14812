BASE <https://w3id.org/itsdata/vocab/>
PREFIX : <https://w3id.org/itsdata/vocab/>
PREFIX cc: <http://creativecommons.org/ns#>
PREFIX dcterms: <http://purl.org/dc/terms/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX vann: <http://purl.org/vocab/vann/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

:itsServiceTerms a owl:Ontology ;
    dcterms:title "Its Service Terms"@en ;
    dcterms:modified "2026-05-29"^^xsd:date ;
    owl:imports <core.ttl> .

:itsServiceProvider a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :delivers ;
            owl:someValuesFrom :itsService ],
        :serviceProvider ;
    skos:definition "[entity](entity.md) that delivers one or more [ITS services](ITS service.md)"@en ;
    skos:historyNote "Introduced in ISO/TS 14812:2022"@en ;
    skos:note "[Cooperative ITS](cooperative ITS.md) services often require multiple entities cooperatively working together to provide a unified [service](service.md) where the individual entities are simultaneously ITS service providers and ITS users."@en ;
    skos:prefLabel "ITS service provider"@en ;
    :altPrefLabel "service provider"@en ;
    :clause "3.5.3.2"@en .

:itsService a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :for ;
            owl:someValuesFrom :itsUser ],
        [ a owl:Restriction ;
            owl:onProperty :fulfils ;
            owl:someValuesFrom :itsUserNeed ],
        :service ;
    skos:definition "provision of functionality that fulfils one or more [ITS user needs](ITS user need.md)"@en ;
    skos:historyNote "2025: Revised to better align with other service terms."@en,
        "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "ITS service"@en ;
    :altPrefLabel "service"@en ;
    :clause "3.5.3.1"@en .

:itsUserNeed a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :desiredResultsOf ;
            owl:someValuesFrom :itsUser ],
        :userNeed ;
    skos:definition "[user need](user need.md) for a [surface transport system](surface transport system.md) benefit that can be met with the use of information, communication, and transducer technologies"@en ;
    skos:example "Increasing safety, sustainability, efficiency and/or comfort."@en ;
    skos:historyNote "2025: Removed reference to an entity external to ITS and replaced \"sensor and/or control\" with \"transducer\"."@en,
        "Introduced in ISO/TS 14812:2022"@en ;
    skos:prefLabel "ITS user need"@en ;
    :altPrefLabel "user need"@en ;
    :clause "3.5.3.4"@en .

:itsUser a owl:Class ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:onProperty :uses ;
            owl:someValuesFrom :surfaceTransportSystem ],
        :user ;
    skos:definition "[entity](entity.md) that uses information, communication, and transducer technologies to achieve benefits when using a [surface transport system](surface transport system.md)"@en ;
    skos:historyNote "2025: Revised to remove circular reference with ITS user need."@en,
        "Introduced in ISO/TS 14812:2025"@en ;
    skos:prefLabel "ITS user"@en ;
    :altPrefLabel "user"@en ;
    :clause "3.5.3.3"@en .
